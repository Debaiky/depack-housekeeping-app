# Email domain allowed to log in (without the @)
ALLOWED_EMAIL_DOMAIN=depack.co

# Google service account (from Google Cloud Console > IAM > Service Accounts)
#
# Easiest option: base64-encode the ENTIRE downloaded JSON key file and paste
# the result here, e.g.: base64 -i service-account-key.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# Alternative (only used if GOOGLE_SERVICE_ACCOUNT_KEY_BASE64 is not set):
# paste the client_email and private_key fields individually. Keep the \n
# characters in the private key as literal \n.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# The ID of the Google Sheet (from its URL: /spreadsheets/d/<THIS_PART>/edit)
GOOGLE_SHEET_ID=

# The ID of the Google Drive folder where photos will be stored (from its URL: /drive/folders/<THIS_PART>)
GOOGLE_DRIVE_FOLDER_ID=

# Random long string used to sign session cookies. Generate with: openssl rand -base64 32
JWT_SECRET=
