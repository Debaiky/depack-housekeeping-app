# Email domain allowed to log in (without the @)
ALLOWED_EMAIL_DOMAIN=depack.co

# Google service account (from Google Cloud Console > IAM > Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON key file. Keep the \n characters as literal \n.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# The ID of the Google Sheet (from its URL: /spreadsheets/d/<THIS_PART>/edit)
GOOGLE_SHEET_ID=

# The ID of the Google Drive folder where photos will be stored (from its URL: /drive/folders/<THIS_PART>)
GOOGLE_DRIVE_FOLDER_ID=

# Random long string used to sign session cookies. Generate with: openssl rand -base64 32
JWT_SECRET=
